# ─────────────────────────────────────────────────────────────
# THE FIT THEORY — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (Free M0 cluster).
# Get it from: Atlas → Database → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/fit-theory?retryWrites=true&w=majority

# JWT signing secret for the admin session cookie.
# Generate a strong random value, e.g. on a terminal:  openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-string

# Admin login password (single-operator dashboard).
ADMIN_PASSWORD=change-this-strong-password

# Cloudinary (Free tier) — Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public values (exposed to the browser).
# WhatsApp number in international format WITHOUT '+' or spaces, e.g. 919876543210
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Full public site URL (no trailing slash). Used to build WhatsApp product links.
NEXT_PUBLIC_SHOP_URL=http://localhost:3000
